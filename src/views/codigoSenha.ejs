<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Verificar Código</title>
    <link rel="stylesheet" href="/assets/css/redefinir_senha.css">
</head>
<body>
    <div class="container">
        <h2>Verificação</h2>
        <p>Digite o código de 8 caracteres enviado ao seu e-mail.</p>
        <div class="input-group">
            <label>Código de Segurança</label>
            <input type="text" maxlength="8" class="code-input" placeholder="XXXXXXXX">
        </div>
        <div class="button-group">
            <button class="btn-primary">Enviar</button>
        </div>
    </div>
</body>
</html>