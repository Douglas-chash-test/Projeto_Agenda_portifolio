<!doctype html>
<html lang="pt-BR" >
  <head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
   
    <link rel="stylesheet" href="/assets/css/login.css">
    <title>Agenda</title>
  </head>
  <body>

<div class="login-container">
        <h2>Acessar Conta</h2>
        <%- include('error') -%>
    <form action="/login/authenticate" method="POST">
        <div class="input-group">
            <label>Usuário ou Email</label>
            <input type="text" name="email_user" placeholder="Digite seu usuário">
        </div>

        <div class="input-group">
            <label>Senha</label>
            <input type="password" name="senha" placeholder="Digite sua senha">
        </div>

        <div class="button-group">
            <button class="btn-login"  type="submit">Login</button>
            <button class="btn-cadastro" onclick="window.location.href='cadastro'" type="button">Cadastrar-se</button>
        </div>
        <a onclick="window.location.href='/esqueceu_senha'" class="redefinir">Esqueci minha senha</a>
    </div>
    </form>
<%- include('flooter') %> 